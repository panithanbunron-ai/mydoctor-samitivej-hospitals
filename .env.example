# Copy to .env and fill in. .env is gitignored; never commit real values here.

# Base URLs for the two apps under test (UAT)
BACKOFFICE_URL=https://mydoctor-backoffice-uat.samitivejhospitals.com/
TELEMEDICINE_URL=https://mydoctor-uat.samitivejhospitals.com/

# Backoffice login account — required only for the LOGIN happy-path (OTP redirect)
# and wrong-password cases; those cases skip when these are unset.
BACKOFFICE_USERNAME=
BACKOFFICE_PASSWORD=
